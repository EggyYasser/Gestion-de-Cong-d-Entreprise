<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox id="mainContainer" prefHeight="600.0" prefWidth="458.0" stylesheets="@../css/support.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.SupportController">
    <children>
        <AnchorPane id="headerPane">
            <children>
                <Label id="titleLabel" layoutX="40.0" layoutY="30.0" text="Need some Help?" />
                <Button id="closeButton" layoutX="400.0" layoutY="20.0" text="✕" />
            </children>
        </AnchorPane>

        <StackPane id="imageContainer">
            <ImageView id="headerImage" fitHeight="150.0" fitWidth="291.0" pickOnBounds="true" preserveRatio="true">
            <image>
               <Image url="@../img/welcome-img.png" />
            </image></ImageView>
        </StackPane>

        <VBox id="formContainer" spacing="20.0">
            <children>
                <Label id="instructionText" text="Describe your question and our specialists will answer you within 24 hours." textAlignment="CENTER" wrapText="true" />

                <VBox spacing="8.0">
                    <children>
                        <Label id="fieldLabel" text="Request Subject" textAlignment="RIGHT">
                     <VBox.margin>
                        <Insets left="30.0" />
                     </VBox.margin></Label>
                        <ComboBox id="subjectComboBox" fx:id="subjectComboBox" prefWidth="370.0" promptText="Technical difficulties">
                     <VBox.margin>
                        <Insets left="10.0" />
                     </VBox.margin></ComboBox>
                    </children>
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label id="fieldLabel" text="Description" textAlignment="JUSTIFY">
                     <VBox.margin>
                        <Insets left="30.0" />
                     </VBox.margin></Label>
                        <TextArea id="descriptionTextArea" fx:id="descriptionTextArea" prefHeight="120.0" prefWidth="370.0" promptText="Add some description of the request">
                     <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </VBox.margin></TextArea>
                    </children>
                </VBox>
            </children>
        </VBox>

        <AnchorPane id="footerPane">
            <children>
                <Button id="sendRequestButton" fx:id="sendRequestButton" layoutX="166.0" layoutY="3.0" text="Send Request" textAlignment="CENTER" />
            </children>
        </AnchorPane>
    </children>
</VBox>
