<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane fx:id="mainBorderPane" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="500.0" minWidth="900.0" prefHeight="500.0" prefWidth="800.0" stylesheets="@../css/menu-conges.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MenuCongesController">
   <left>
      <VBox fx:id="sidebarVBox" alignment="TOP_CENTER" maxHeight="1.7976931348623157E308" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <ImageView fx:id="logoImageView" fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </ImageView>
            <Button fx:id="dashboardButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Dashboard">
               <VBox.margin>
                  <Insets left="15.0" right="15.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="congeesButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Congees">
               <VBox.margin>
                  <Insets left="15.0" right="15.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="employeesButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="active-button" text="Employees">
               <VBox.margin>
                  <Insets left="15.0" right="15.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="abonnementsButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Abonnements">
               <VBox.margin>
                  <Insets left="15.0" right="15.0" />
               </VBox.margin>
            </Button>
            <Region VBox.vgrow="ALWAYS" />
            <Button fx:id="logoutButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Logout">
               <VBox.margin>
                  <Insets bottom="20.0" left="15.0" right="15.0" />
               </VBox.margin>
            </Button>
         </children>
         <padding>
            <Insets bottom="10.0" top="10.0" />
         </padding>
      </VBox>
   </left>
   <center>
      <VBox fx:id="mainContentVBox" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <HBox fx:id="topBarHBox" alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="15.0">
               <children>
                  <TextField fx:id="searchTextField" promptText="Search..." HBox.hgrow="ALWAYS">
                     <HBox.margin>
                        <Insets left="15.0" />
                     </HBox.margin>
                  </TextField>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="notificationButton" mnemonicParsing="false" text="🔔">
                     <HBox.margin>
                        <Insets right="10.0" />
                     </HBox.margin>
                  </Button>
                  <ComboBox fx:id="profileComboBox" prefHeight="40.0" prefWidth="162.0" promptText="Profile ">
                     <HBox.margin>
                        <Insets right="15.0" />
                     </HBox.margin>
                  </ComboBox>
               </children>
               <padding>
                  <Insets bottom="10.0" top="10.0" />
               </padding>
            </HBox>

            <HBox fx:id="headerHBox" alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="10.0">
               <children>
                  <Text fx:id="pageTitleText" strokeType="OUTSIDE" strokeWidth="0.0" text="Gestion Des Conges" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="addRequestButton" mnemonicParsing="false" text="Ajouter une Demande +">
                     <HBox.margin>
                        <Insets right="15.0" />
                     </HBox.margin>
                  </Button>
               </children>
               <padding>
                  <Insets left="15.0" right="15.0" />
               </padding>
            </HBox>

            <HBox fx:id="contentAreaHBox" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="15.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox fx:id="filtersVBox" maxHeight="1.7976931348623157E308" minWidth="150.0" prefWidth="200.0" spacing="10.0">
                     <children>
                        <Label fx:id="filtersLabel" text="Filters" />
                        <Button fx:id="allFilterButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="All" />
                        <Button fx:id="pendingFilterButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Pending" />
                        <Button fx:id="approvedFilterButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Approved" />
                        <Button fx:id="rejectedFilterButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Rejected" />
                        <Region VBox.vgrow="ALWAYS" />
                     </children>
                     <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                     </padding>
                  </VBox>

                  <ListView fx:id="congesListView" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
               </children>
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" />
               </padding>
            </HBox>
         </children>
         <padding>
            <Insets top="15.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
